<html lang="es">
<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/jpeg" href="/images/favicon.jpeg" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="robots" content="noindex, nofollow" />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
	<title>Seguro de Gastos Finales — Hasta $25,000 en Cobertura</title>
	<style>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html, body {
			overflow-x: hidden;
		}

		body {
			font-family: 'Open Sans', Arial, sans-serif;
			background: #f7f7f7;
			color: #111111;
			line-height: 1.6;
		}

		/* ─── TOP BAR ─── */
		.top-bar {
			background: #b71c1c;
			color: #ffffff;
			text-align: center;
			padding: 0.65rem 1rem;
			font-size: 0.9rem;
			font-weight: 700;
			letter-spacing: 0.01em;
		}

		/* ─── MAIN WRAP ─── */
		.main-wrap {
			max-width: 760px;
			margin: 0 auto;
			padding: 0 1.25rem 3rem;
		}

		/* ─── ARTICLE HEADER ─── */
		.article-header {
			text-align: center;
			padding: 2rem 0 1.5rem;
			border-bottom: 1px solid #e0e0e0;
			margin-bottom: 1.5rem;
		}

		.article-title {
			font-size: clamp(1.6rem, 4.5vw, 2.4rem);
			font-weight: 800;
			color: #0d0d0d;
			line-height: 1.2;
		}

		/* ─── HERO IMAGE ─── */
		.hero-img-wrap {
			text-align: center;
			margin-bottom: 1.5rem;
		}

		.hero-img {
			width: 100%;
			max-width: 560px;
			border-radius: 6px;
			display: block;
			margin: 0 auto;
		}

		.hero-img-caption {
			font-size: 0.72rem;
			color: #999;
			margin-top: 0.4rem;
		}

		/* ─── BODY COPY ─── */
		.body-copy {
			font-size: 1.05rem;
			color: #1a1a1a;
			margin-bottom: 1.2rem;
			line-height: 1.75;
		}

		.body-copy strong {
			color: #0d0d0d;
		}

		.pull-quote {
			border-left: 4px solid #b71c1c;
			padding: 0.75rem 1.2rem;
			margin: 1.5rem 0;
			background: #fff5f5;
			font-size: 1.1rem;
			font-style: italic;
			color: #333;
			border-radius: 0 6px 6px 0;
		}

		/* ─── BENEFITS BOX ─── */
		.benefits-box {
			background: #ffffff;
			border: 1px solid #e0e0e0;
			border-top: 4px solid #b71c1c;
			border-radius: 6px;
			padding: 1.5rem 1.75rem;
			margin: 1.75rem 0;
		}

		.benefits-box h3 {
			font-size: 1rem;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: #b71c1c;
			margin-bottom: 1rem;
		}

		.benefits-list {
			list-style: none;
			display: flex;
			flex-direction: column;
			gap: 0.65rem;
		}

		.benefits-list li {
			display: flex;
			align-items: flex-start;
			gap: 0.6rem;
			font-size: 0.97rem;
			color: #1a1a1a;
			font-weight: 600;
		}

		.benefits-list li::before {
			content: "✔";
			color: #2e7d32;
			font-weight: 900;
			flex-shrink: 0;
			margin-top: 0.1rem;
		}

		/* ─── CTA SECTION ─── */
		.cta-section {
			background: #1a3a6e;
			border-radius: 8px;
			padding: 1.75rem 1.5rem 2rem;
			text-align: center;
			margin: 2rem 0;
		}

		.cta-section .cta-label {
			color: #ffffff;
			font-size: 1rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			margin-bottom: 0.4rem;
		}

		.cta-section .cta-sublabel {
			color: rgba(255,255,255,0.75);
			font-size: 0.88rem;
			margin-bottom: 1.4rem;
		}

		.cta-btn {
			display: inline-block;
			background: #c62828;
			color: #ffffff;
			font-family: 'Open Sans', Arial, sans-serif;
			font-size: 1.2rem;
			font-weight: 800;
			padding: 1rem 2.6rem;
			border-radius: 6px;
			text-decoration: none;
			letter-spacing: 0.01em;
			box-shadow: 0 4px 18px rgba(0,0,0,0.3);
			transition: background 0.2s, transform 0.15s;
			text-transform: uppercase;
		}

		.cta-btn:hover {
			background: #8e1a1a;
			transform: translateY(-2px);
		}

		.cta-note {
			color: rgba(255,255,255,0.65);
			font-size: 0.75rem;
			margin-top: 0.85rem;
		}

		/* ─── TESTIMONIALS ─── */
		.testimonials {
			margin: 2rem 0;
		}

		.testimonials h3 {
			font-size: 1rem;
			font-weight: 800;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: #444;
			margin-bottom: 1rem;
		}

		.testimonial {
			background: #ffffff;
			border: 1px solid #e8e8e8;
			border-radius: 6px;
			padding: 1.1rem 1.3rem;
			margin-bottom: 0.9rem;
		}

		.testimonial-stars {
			color: #f59e0b;
			font-size: 0.95rem;
			letter-spacing: 2px;
			margin-bottom: 0.4rem;
		}

		.testimonial-text {
			font-size: 0.92rem;
			font-style: italic;
			color: #333;
			margin-bottom: 0.4rem;
			line-height: 1.6;
		}

		.testimonial-author {
			font-size: 0.8rem;
			font-weight: 700;
			color: #b71c1c;
		}

		/* ─── TRUST STRIP ─── */
		.trust-strip {
			background: #ffffff;
			border: 1px solid #e0e0e0;
			border-radius: 6px;
			padding: 1rem 1.25rem;
			text-align: center;
			margin: 1.5rem 0;
		}

		.trust-items {
			display: flex;
			justify-content: center;
			gap: 1.5rem;
			flex-wrap: wrap;
		}

		.trust-item {
			font-size: 0.8rem;
			font-weight: 700;
			color: #333;
			display: flex;
			align-items: center;
			gap: 0.3rem;
		}

		/* ─── FOOTER ─── */
		footer {
			text-align: center;
			padding: 1.5rem 0.5rem;
			border-top: 1px solid #e0e0e0;
			margin-top: 1rem;
		}

		.disclaimer {
			font-size: 0.63rem;
			line-height: 1.65;
			color: #aaaaaa;
			margin-bottom: 0.6rem;
			text-align: left;
		}

		footer .footer-links {
			font-size: 0.75rem;
			color: #888;
			text-align: center;
		}

		footer .footer-links a {
			color: #555;
			text-decoration: underline;
		}

		/* ─── RESPONSIVE ─── */
		@media (max-width: 520px) {
			.article-title {
				font-size: 1.35rem;
			}
			.cta-btn {
				font-size: 1rem;
				padding: 0.9rem 1.6rem;
			}
		}
	</style>

