	<title>Seniors: Qualify for $25,000–$40,000 Life Insurance Coverage</title>
	<style>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html, body {
			overflow-x: hidden;
		}

		body {
			font-family: 'Open Sans', Arial, sans-serif;
			background: #ffffff;
			color: #111111;
			line-height: 1.5;
		}

		/* ─── TOP BAR ─── */
		.top-bar {
			background: #1f4d1f;
			color: #ffffff;
			text-align: center;
			padding: 0.6rem 1rem;
			font-size: 0.95rem;
			font-weight: 700;
			letter-spacing: 0.01em;
		}

		/* ─── MAIN CONTENT ─── */
		.main-wrap {
			max-width: 780px;
			margin: 0 auto;
			padding: 2rem 1.25rem 3rem;
			text-align: center;
		}

		/* ─── HEADLINE ─── */
		.headline {
			font-size: clamp(1.3rem, 3.8vw, 1.75rem);
			font-weight: 800;
			line-height: 1.3;
			color: #0a0a2a;
			margin-bottom: 1.5rem;
			max-width: 100%;
		}

		.headline .attention {
			color: #c94c00;
		}

		.headline .money {
			color: #1a8a1a;
		}

		/* ─── HERO IMAGE ─── */
		.hero-img {
			width: 90%;
			max-width: 468px;
			border-radius: 6px;
			display: block;
			margin: 0 auto 1.5rem;
		}

		/* ─── SUBTEXT ─── */
		.subtext {
			font-size: 1.05rem;
			color: #222222;
			font-weight: 600;
			max-width: 620px;
			margin: 0 auto 2rem;
		}

		/* ─── CALL BAR ─── */
		.call-bar {
			background: #1a3a6e;
			border-radius: 6px;
			padding: 1.4rem 1.5rem 1.8rem;
			text-align: center;
		}

		.call-bar-label {
			color: #ffffff;
			font-size: 1rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			margin-bottom: 1.2rem;
		}

		.call-btn {
			display: inline-block;
			background: #22aa22;
			color: #ffffff;
			font-family: 'Open Sans', Arial, sans-serif;
			font-size: 1.25rem;
			font-weight: 800;
			padding: 1rem 2.8rem;
			border-radius: 6px;
			text-decoration: none;
			letter-spacing: 0.02em;
			text-transform: uppercase;
			box-shadow: 0 4px 18px rgba(0,0,0,0.25);
			transition: background 0.2s, transform 0.15s;
		}

		.call-btn:hover {
			background: #1a8a1a;
			transform: translateY(-2px);
		}

		.call-note {
			color: rgba(255,255,255,0.75);
			font-size: 0.78rem;
			margin-top: 0.8rem;
		}

		/* ─── FOOTER ─── */
		footer {
			text-align: center;
			padding: 1.5rem 1.5rem;
			color: #888888;
			border-top: 1px solid #e0e0e0;
			margin-top: 2rem;
			max-width: 780px;
			margin-left: auto;
			margin-right: auto;
		}

		footer a {
			color: #555555;
			text-decoration: underline;
			font-size: 0.78rem;
		}

		.disclaimer {
			font-size: 0.65rem;
			line-height: 1.6;
			color: #aaaaaa;
			margin-bottom: 0.5rem;
		}

		@media (max-width: 520px) {
			.headline {
				font-size: 1.35rem;
			}
			.call-btn {
				font-size: 1.05rem;
				padding: 0.9rem 1.8rem;
			}
		}
	</style>

