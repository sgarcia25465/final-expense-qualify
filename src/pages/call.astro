<html lang="en">
<head>
	<meta charset="utf-8" />
	<link rel="icon" type="image/jpeg" href="/images/favicon.jpeg" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<meta name="robots" content="noindex, nofollow" />
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	<title>Claim Your Burial Coverage Benefit — Call Now</title>
	<style>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		:root {
			--primary: #c62828;
			--primary-dark: #8e1a1a;
			--primary-light: #ef5350;
			--dark: #1a1a1a;
			--dark-gray: #3d3d3d;
			--medium-gray: #6b6b6b;
			--light-gray: #e0e0e0;
			--very-light: #f8f8f8;
			--white: #ffffff;
			--green: #2e7d32;
			--green-light: #e8f5e9;
		}

		html, body {
			overflow-x: hidden;
		}

		body {
			font-family: 'Outfit', sans-serif;
			color: var(--dark);
			background: var(--very-light);
			line-height: 1.6;
			min-height: 100vh;
		}

		/* ─── TOP BAR ─── */
		.top-bar {
			background: var(--primary);
			color: var(--white);
			text-align: center;
			padding: 0.55rem 1rem;
			font-size: 0.85rem;
			font-weight: 600;
			letter-spacing: 0.02em;
		}

		/* ─── REVIEWS SLIDER ─── */
		.reviews-bar {
			background: var(--white);
			border-top: 1px solid var(--light-gray);
			border-bottom: 1px solid var(--light-gray);
			padding: 0.9rem 0;
			overflow: hidden;
		}

		.reviews-track-wrap {
			max-width: 860px;
			margin: 0 auto;
			position: relative;
			overflow: hidden;
		}

		.reviews-track {
			display: flex;
			transition: transform 0.5s ease;
		}

		.review-slide {
			min-width: 100%;
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 0.75rem;
			padding: 0 1rem;
			text-align: center;
			flex-wrap: wrap;
		}

		.review-stars {
			color: #f59e0b;
			font-size: 1rem;
			letter-spacing: 2px;
		}

		.review-text {
			font-size: 0.9rem;
			color: var(--dark-gray);
			font-style: italic;
		}

		.review-author {
			font-size: 0.85rem;
			font-weight: 700;
			color: var(--primary);
		}

		.review-dots {
			display: flex;
			justify-content: center;
			gap: 6px;
			margin-top: 0.5rem;
		}

		.review-dot {
			width: 7px;
			height: 7px;
			border-radius: 50%;
			background: var(--light-gray);
			cursor: pointer;
			transition: background 0.3s;
		}

		.review-dot.active {
			background: var(--primary);
		}

		/* ─── HERO ─── */
		.hero {
			background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 60%, #d84315 100%);
			color: var(--white);
			text-align: center;
			padding: 3.5rem 1.5rem 4rem;
		}

		.hero-eyebrow {
			display: inline-block;
			background: rgba(255,255,255,0.15);
			border: 1px solid rgba(255,255,255,0.3);
			color: #fff;
			font-size: 0.8rem;
			font-weight: 700;
			letter-spacing: 0.1em;
			text-transform: uppercase;
			padding: 0.35rem 1rem;
			border-radius: 100px;
			margin-bottom: 1.2rem;
		}

		.hero h1 {
			font-size: clamp(1.8rem, 5vw, 2.8rem);
			font-weight: 800;
			line-height: 1.15;
			margin-bottom: 1rem;
			text-shadow: 0 2px 6px rgba(0,0,0,0.2);
		}

		.hero h1 em {
			font-style: normal;
			color: #ffcdd2;
		}

		.hero p {
			font-size: 1.05rem;
			opacity: 0.9;
			max-width: 560px;
			margin: 0 auto 2rem;
		}

		/* ─── CALL SECTION ─── */
		.call-section {
			max-width: 700px;
			margin: 0 auto;
			padding: 2.5rem 1.5rem 4rem;
		}

		.call-card {
			background: var(--white);
			border-radius: 20px;
			box-shadow: 0 4px 32px rgba(0,0,0,0.1);
			padding: 3rem 2.5rem;
			text-align: center;
		}

		.call-icon {
			font-size: 3.5rem;
			margin-bottom: 1rem;
		}

		.call-card h2 {
			font-size: 1.7rem;
			font-weight: 800;
			color: var(--dark);
			margin-bottom: 0.75rem;
		}

		.call-card p {
			font-size: 0.95rem;
			color: var(--medium-gray);
			max-width: 440px;
			margin: 0 auto 1.8rem;
		}

		.payout-box {
			background: linear-gradient(135deg, #fff5f5 0%, #fce4e4 100%);
			border: 2px solid #ef9a9a;
			border-radius: 12px;
			padding: 1.2rem 1.5rem;
			margin: 0 0 1.8rem;
			text-align: center;
		}

		.payout-box .payout-label {
			font-size: 0.78rem;
			font-weight: 700;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--primary);
			margin-bottom: 0.3rem;
		}

		.payout-box .payout-amount {
			font-size: 2.4rem;
			font-weight: 800;
			color: var(--primary);
			line-height: 1.1;
		}

		.payout-box .payout-desc {
			font-size: 0.8rem;
			color: var(--medium-gray);
			margin-top: 0.3rem;
		}

		.cta-btn {
			display: inline-block;
			background: var(--primary);
			color: var(--white);
			font-family: 'Outfit', sans-serif;
			font-size: 1.15rem;
			font-weight: 700;
			padding: 1.1rem 2.5rem;
			border-radius: 10px;
			text-decoration: none;
			border: none;
			cursor: pointer;
			transition: background 0.2s, transform 0.15s;
			box-shadow: 0 4px 16px rgba(198,40,40,0.35);
		}

		.cta-btn:hover {
			background: var(--primary-dark);
			transform: translateY(-1px);
		}

		.cta-note {
			font-size: 0.78rem;
			color: var(--medium-gray);
			margin-top: 0.85rem;
		}

		/* ─── TRUST STRIP ─── */
		.trust-strip {
			background: var(--very-light);
			border-top: 1px solid var(--light-gray);
			padding: 1.5rem 1.5rem;
			text-align: center;
		}

		.trust-strip p {
			font-size: 0.8rem;
			color: var(--medium-gray);
		}

		.trust-items {
			display: flex;
			justify-content: center;
			gap: 2rem;
			flex-wrap: wrap;
			margin-top: 0.75rem;
		}

		.trust-item {
			font-size: 0.8rem;
			font-weight: 600;
			color: var(--dark-gray);
			display: flex;
			align-items: center;
			gap: 0.3rem;
		}

		/* ─── FOOTER ─── */
		footer {
			background: var(--dark);
			color: rgba(255,255,255,0.5);
			text-align: center;
			padding: 1.5rem 1rem;
			font-size: 0.78rem;
		}

		footer a {
			color: rgba(255,255,255,0.6);
			text-decoration: none;
		}

		/* ─── RESPONSIVE ─── */
		@media (max-width: 520px) {
			.hero h1 {
				font-size: 1.6rem;
			}

			.call-card {
				padding: 2rem 1.2rem;
			}

			.payout-box .payout-amount {
				font-size: 2rem;
			}

			.cta-btn {
				font-size: 1rem;
				padding: 1rem 1.8rem;
			}
		}
	</style>

	<!-- Meta Pixel Code -->
